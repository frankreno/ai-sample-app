# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite
db/sitecheck.db
db/*.db-shm
db/*.db-wal
db/*.db-journal

# runtime uploads and generated reports
public/uploads/*
!public/uploads/.gitkeep
public/reports/*
!public/reports/.gitkeep

# Cursor (keep project rules, ignore user-specific config)
.cursor/*
!.cursor/rules/
